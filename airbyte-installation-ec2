    <!-- 02 INSTALL DOCKER -->
    <section id="docker">
      <div class="sec-header">
        <div class="sec-num">02</div>
        <div class="sec-titles"><div class="sec-phase">Phase 2</div><div class="sec-title">Install Docker Engine</div></div>
      </div>
      <div class="divider"></div>
      <div class="callout c-tip">
        <span class="c-icon">🐧</span>
        <span>You're on <strong>Ubuntu</strong> — use <code>apt-get</code> instead of <code>yum</code>. The default SSH user is <code>ubuntu</code>, not <code>ec2-user</code>.</span>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step-head"><div class="step-n">1</div><div class="step-name">Update Package Index & Install Dependencies</div><span class="step-tag">apt</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="ck">sudo</span> <span class="cf">apt-get</span> update
<span class="ck">sudo</span> <span class="cf">apt-get</span> install -y <span class="cs">ca-certificates curl gnupg lsb-release</span></pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">2</div><div class="step-name">Add Docker's Official GPG Key</div><span class="step-tag">security</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="ck">sudo</span> <span class="cf">install</span> -m 0755 -d /etc/apt/keyrings
<span class="cf">curl</span> -fsSL https://download.docker.com/linux/ubuntu/gpg \
  | <span class="ck">sudo</span> <span class="cf">gpg</span> --dearmor -o /etc/apt/keyrings/docker.gpg
<span class="ck">sudo</span> <span class="cf">chmod</span> a+r /etc/apt/keyrings/docker.gpg</pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">3</div><div class="step-name">Add Docker Repository</div><span class="step-tag">repo</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="cf">echo</span> \
  <span class="cs">"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
  https://download.docker.com/linux/ubuntu \
  $(lsb_release -cs) stable"</span> \
  | <span class="ck">sudo</span> <span class="cf">tee</span> /etc/apt/sources.list.d/docker.list > /dev/null</pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">4</div><div class="step-name">Install Docker Engine</div><span class="step-tag">install</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="ck">sudo</span> <span class="cf">apt-get</span> update
<span class="ck">sudo</span> <span class="cf">apt-get</span> install -y <span class="cs">docker-ce docker-ce-cli containerd.io</span></pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">5</div><div class="step-name">Add ubuntu User to Docker Group</div><span class="step-tag">permissions</span></div>
          <div class="step-body">
            <div class="callout c-warn"><span class="c-icon">⚠️</span><span>On Ubuntu EC2 the default user is <strong>ubuntu</strong> — not <code>ec2-user</code>.</span></div>
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="ck">sudo</span> <span class="cf">usermod</span> -a -G docker ubuntu</pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">6</div><div class="step-name">Start Docker & Enable on Boot</div><span class="step-tag">systemctl</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="ck">sudo</span> <span class="cf">systemctl</span> start docker
<span class="ck">sudo</span> <span class="cf">systemctl</span> enable docker</pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">7</div><div class="step-name">Exit & Reconnect to EC2</div><span class="step-tag">mandatory</span></div>
          <div class="step-body">
            <div class="callout c-warn"><span class="c-icon">⚠️</span><span>This step is <strong>mandatory</strong>. The docker group change only takes effect after a fresh SSH session.</span></div>
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre>exit
<span class="cf">ssh</span> -i your-key.pem ubuntu@your-ec2-public-ip</pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">8</div><div class="step-name">Verify Docker is Running</div><span class="step-tag">verify</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="cf">docker</span> ps</pre></div>
            <div class="callout c-ok"><span class="c-icon">✅</span><span>You should see an empty table with no permission errors. If errors appear, repeat the reconnect step.</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 03 INSTALL abctl -->
    <section id="abctl">
      <div class="sec-header">
        <div class="sec-num">03</div>
        <div class="sec-titles"><div class="sec-phase">Phase 3</div><div class="sec-title">Install abctl</div></div>
      </div>
      <div class="divider"></div>
      <div class="steps">
        <div class="step">
          <div class="step-head"><div class="step-n">1</div><div class="step-name">Download & Install abctl</div><span class="step-tag">curl</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="cf">curl</span> -LsfS https://get.airbyte.com | bash -</pre></div>
          </div>
        </div>
        <div class="step">
          <div class="step-head"><div class="step-n">2</div><div class="step-name">Verify abctl Installation</div><span class="step-tag">verify</span></div>
          <div class="step-body">
            <div class="code-wrap"><div class="code-top"><div class="code-dots"><span class="d1"></span><span class="d2"></span><span class="d3"></span></div><span class="code-lang">bash</span><button class="copy-btn" onclick="doCopy(this)">⎘ copy</button></div>
            <pre><span class="cf">abctl</span> version</pre></div>
            <div class="callout c-ok"><span class="c-icon">✅</span><span>You should see the installed version printed. abctl is ready!</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 04 INSTALL AIRBYTE -->
