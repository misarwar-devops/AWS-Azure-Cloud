<title>Airbyte on Ubuntu EC2 — Setup Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Unbounded:wght@400;700;900&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #060810;
  --surface: #0d1117;
  --surface2: #161b27;
  --border: #1e2d45;
  --border2: #243550;
  --green: #00ff88;
  --green2: #00cc6a;
  --cyan: #00e5ff;
  --blue: #3d8bff;
  --amber: #ffb800;
  --red: #ff4d6a;
  --purple: #a855f7;
  --text: #cdd9f0;
  --muted: #4a6080;
  --font-head: 'Unbounded', sans-serif;
  --font-mono: 'Space Mono', monospace;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: var(--font-mono); overflow-x: hidden; cursor: none; }
.cursor { position:fixed; width:10px; height:10px; background:var(--green); border-radius:50%; pointer-events:none; z-index:9999; box-shadow:0 0 12px var(--green),0 0 30px rgba(0,255,136,.3); }
.cursor-ring { position:fixed; width:32px; height:32px; border:1px solid rgba(0,255,136,.4); border-radius:50%; pointer-events:none; z-index:9998; transition:all .15s ease; }
body::after { content:''; position:fixed; inset:0; background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.07) 2px,rgba(0,0,0,.07) 4px); pointer-events:none; z-index:100; }

/* HERO */
.hero { position:relative; z-index:1; min-height:100vh; display:flex; flex-direction:column; justify-content:center; padding:60px 60px 80px; overflow:hidden; }
.hero-glow { position:absolute; top:-200px; left:-200px; width:700px; height:700px; background:radial-gradient(circle,rgba(0,255,136,.06) 0%,transparent 70%); pointer-events:none; animation:breathe 6s ease-in-out infinite; }
.hero-glow2 { position:absolute; bottom:-300px; right:-100px; width:600px; height:600px; background:radial-gradient(circle,rgba(0,229,255,.04) 0%,transparent 70%); pointer-events:none; animation:breathe 8s ease-in-out infinite reverse; }
@keyframes breathe { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.1);opacity:.7} }
.hero-tag { display:inline-flex; align-items:center; gap:10px; font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--green); margin-bottom:32px; animation:fadeUp .6s ease both; }
.hero-tag::before { content:''; display:block; width:40px; height:1px; background:var(--green); }
.blink { animation:blink 1s step-end infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
h1 { font-family:var(--font-head); font-size:clamp(2.8rem,6vw,5.5rem); font-weight:900; line-height:1.0; letter-spacing:-.03em; margin-bottom:28px; animation:fadeUp .7s ease .1s both; }
h1 .line1 { display:block; color:#fff; }
h1 .line2 { display:block; background:linear-gradient(90deg,var(--green) 0%,var(--cyan) 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.hero-sub { font-size:13px; color:var(--muted); max-width:520px; line-height:1.8; margin-bottom:48px; animation:fadeUp .7s ease .2s both; }
.hero-stats { display:flex; gap:40px; flex-wrap:wrap; animation:fadeUp .7s ease .3s both; }
.stat { display:flex; flex-direction:column; gap:4px; }
.stat-val { font-family:var(--font-head); font-size:1.6rem; font-weight:700; color:var(--green); line-height:1; }
.stat-label { font-size:10px; color:var(--muted); letter-spacing:.1em; text-transform:uppercase; }
.stat-divider { width:1px; background:var(--border); align-self:stretch; }
.prompt-bar { display:inline-flex; align-items:center; gap:10px; background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:10px 18px; font-size:13px; margin-top:40px; animation:fadeUp .7s ease .4s both; flex-wrap:wrap; }
.prompt-user{color:var(--green)} .prompt-host{color:var(--cyan)} .prompt-path{color:var(--blue)} .prompt-cmd{color:var(--text)}

/* LAYOUT */
.page { position:relative; z-index:1; max-width:1200px; margin:0 auto; padding:0 60px 100px; display:grid; grid-template-columns:220px 1fr; gap:60px; align-items:start; }
@media(max-width:900px){.page{grid-template-columns:1fr;padding:0 24px 80px}.hero{padding:60px 24px}.sidebar{display:none}}

/* SIDEBAR */
.sidebar { position:sticky; top:32px; }
.nav-label { font-size:9px; letter-spacing:.2em; text-transform:uppercase; color:var(--muted); margin-bottom:20px; padding-left:16px; border-left:2px solid var(--border); }
.nav-item { display:flex; align-items:center; gap:12px; padding:10px 16px; border-left:2px solid var(--border); color:var(--muted); text-decoration:none; font-size:11px; letter-spacing:.04em; transition:all .2s; position:relative; }
.nav-item:hover,.nav-item.active { color:var(--green); border-left-color:var(--green); }
.nav-num { font-size:9px; color:var(--muted); min-width:18px; }

/* SECTIONS */
.content section { margin-bottom:72px; }
.sec-header { display:flex; align-items:flex-start; gap:20px; margin-bottom:36px; }
.sec-num { font-family:var(--font-head); font-size:3.5rem; font-weight:900; line-height:1; color:var(--surface2); min-width:60px; letter-spacing:-.04em; user-select:none; }
.sec-titles { flex:1; padding-top:6px; }
.sec-phase { font-size:9px; letter-spacing:.2em; text-transform:uppercase; color:var(--green); margin-bottom:6px; }
.sec-title { font-family:var(--font-head); font-size:1.4rem; font-weight:700; color:#fff; line-height:1.2; }
.divider { height:1px; background:linear-gradient(90deg,var(--green) 0%,transparent 60%); margin-bottom:36px; opacity:.3; }

/* SPEC GRID */
.spec-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; margin-bottom:28px; }
@media(max-width:600px){.spec-grid{grid-template-columns:1fr}}
.spec-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:20px; position:relative; overflow:hidden; transition:border-color .25s,transform .25s; }
.spec-card:hover { border-color:var(--border2); transform:translateY(-2px); }
.spec-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,var(--green),transparent); opacity:0; transition:opacity .25s; }
.spec-card:hover::before{opacity:1}
.spec-label { font-size:9px; letter-spacing:.15em; text-transform:uppercase; color:var(--muted); margin-bottom:10px; }
.spec-row { display:flex; justify-content:space-between; align-items:center; margin-top:6px; font-size:12px; }
.spec-row .key{color:var(--muted);font-size:11px} .spec-row .min{color:var(--amber)} .spec-row .rec{color:var(--green)}

/* CHECKLIST */
.checklist { display:flex; flex-direction:column; gap:8px; }
.chk { display:flex; align-items:center; gap:14px; background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:14px 18px; cursor:pointer; transition:all .2s; user-select:none; }
.chk:hover{border-color:var(--border2)} .chk.done{border-color:rgba(0,255,136,.2);background:rgba(0,255,136,.03)}
.chk-box { width:22px; height:22px; border-radius:6px; border:2px solid var(--border2); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all .2s; font-size:12px; }
.chk.done .chk-box{background:var(--green);border-color:var(--green);color:#000;font-weight:700}
.chk-text{font-size:13px;transition:color .2s} .chk.done .chk-text{color:var(--muted);text-decoration:line-through}
.chk-tag { margin-left:auto; font-size:9px; letter-spacing:.1em; padding:3px 10px; border-radius:100px; border:1px solid var(--border); color:var(--muted); text-transform:uppercase; white-space:nowrap; }

/* CODE */
.code-wrap { border-radius:14px; overflow:hidden; border:1px solid var(--border); margin:16px 0; background:var(--surface); }
.code-top { display:flex; align-items:center; justify-content:space-between; padding:10px 16px; background:var(--surface2); border-bottom:1px solid var(--border); }
.code-dots{display:flex;gap:7px} .code-dots span{width:11px;height:11px;border-radius:50%;cursor:pointer}
.d1{background:#ff5f57} .d2{background:#ffbd2e} .d3{background:#28ca41}
.code-lang { font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); }
.copy-btn { display:flex; align-items:center; gap:6px; background:none; border:1px solid var(--border); color:var(--muted); padding:5px 14px; border-radius:6px; cursor:pointer; font-family:var(--font-mono); font-size:10px; letter-spacing:.06em; transition:all .2s; }
.copy-btn:hover,.copy-btn.copied{border-color:var(--green);color:var(--green)}
pre { padding:22px 20px; overflow-x:auto; font-size:13px; line-height:1.75; tab-size:2; }
.cm{color:#3d5a7a;font-style:italic} .ck{color:var(--cyan)} .cv{color:#80cbc4} .cs{color:#c3e88d} .cf{color:var(--green);font-weight:700} .co{color:var(--amber)}

/* STEPS */
.steps{display:flex;flex-direction:column;gap:12px}
.step { background:var(--surface); border:1px solid var(--border); border-radius:14px; overflow:hidden; transition:border-color .2s; }
.step:hover{border-color:var(--border2)}
.step-head { display:flex; align-items:center; gap:18px; padding:18px 22px; }
.step-n { font-family:var(--font-head); font-size:11px; font-weight:700; color:var(--bg); background:var(--green); width:30px; height:30px; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.step-name { font-size:14px; font-weight:700; color:#fff; flex:1; }
.step-tag { font-size:9px; letter-spacing:.1em; text-transform:uppercase; padding:4px 12px; border-radius:100px; border:1px solid var(--border); color:var(--muted); }
.step-body { padding:0 22px 22px; border-top:1px solid var(--border); }
.step-desc { font-size:12px; color:var(--muted); margin:14px 0 6px; line-height:1.7; }

/* CALLOUTS */
.callout { display:flex; gap:14px; padding:14px 18px; border-radius:10px; font-size:12px; line-height:1.7; margin:12px 0; }
.c-warn{background:rgba(255,184,0,.06);border:1px solid rgba(255,184,0,.2);color:#fde68a}
.c-info{background:rgba(0,229,255,.06);border:1px solid rgba(0,229,255,.2);color:#a5f3fc}
.c-ok{background:rgba(0,255,136,.06);border:1px solid rgba(0,255,136,.2);color:#a7f3d0}
.c-tip{background:rgba(168,85,247,.06);border:1px solid rgba(168,85,247,.2);color:#e9d5ff}
.c-icon{font-size:16px;flex-shrink:0}

/* DIFF TABLE */
.diff-table { width:100%; border-collapse:collapse; font-size:12px; border-radius:12px; overflow:hidden; border:1px solid var(--border); }
.diff-table th { background:var(--surface2); padding:12px 16px; text-align:left; font-size:9px; letter-spacing:.15em; text-transform:uppercase; color:var(--muted); border-bottom:1px solid var(--border); }
.diff-table td { padding:13px 16px; border-top:1px solid var(--border); }
.diff-table tr:hover td{background:var(--surface2)}
.diff-table td:first-child{color:var(--muted)} .diff-table td:nth-child(2){color:var(--amber);font-family:var(--font-mono)} .diff-table td:nth-child(3){color:var(--green);font-family:var(--font-mono)}
.diff-badge { display:inline-block; padding:2px 10px; border-radius:4px; font-size:10px; font-weight:700; background:rgba(0,255,136,.12); color:var(--green); border:1px solid rgba(0,255,136,.2); }

/* TIMELINE */
.timeline{display:flex;flex-direction:column}
.tl-item{display:flex;gap:20px}
.tl-line{display:flex;flex-direction:column;align-items:center;width:20px;flex-shrink:0}
.tl-dot{width:14px;height:14px;border-radius:50%;background:var(--green);box-shadow:0 0 10px var(--green);flex-shrink:0;margin-top:4px;z-index:1}
.tl-connector{width:2px;flex:1;min-height:24px;background:linear-gradient(to bottom,var(--green),transparent);margin:4px 0}
.tl-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:16px 20px; margin-bottom:10px; flex:1; transition:border-color .2s; }
.tl-card:hover{border-color:rgba(0,255,136,.3)}
.tl-phase{font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--green);margin-bottom:6px}
.tl-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:6px}
.tl-desc{font-size:12px;color:var(--muted);line-height:1.7}

/* CMD GRID */
.cmd-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:10px}
.cmd-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 18px;transition:all .2s;cursor:default}
.cmd-card:hover{border-color:rgba(0,255,136,.3);background:rgba(0,255,136,.02)}
.cmd-code{font-size:12px;color:var(--cyan);margin-bottom:6px;word-break:break-all}
.cmd-desc{font-size:11px;color:var(--muted)}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* FOOTER */
footer { position:relative; z-index:1; border-top:1px solid var(--border); padding:32px 60px; display:flex; align-items:center; justify-content:space-between; font-size:11px; color:var(--muted); flex-wrap:wrap; gap:12px; }
.logo{font-family:var(--font-head);font-size:13px;font-weight:700;color:var(--green);letter-spacing:.05em}
.footer-right{display:flex;gap:24px;flex-wrap:wrap}
.footer-right span{color:var(--muted)} .footer-right span b{color:var(--cyan)}

.slabel{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;display:block}
</style>
</head>
